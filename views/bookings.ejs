<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('navbar') %>
  <div class="container py-5">
    <h1 class="mb-4">Bookings</h1>
    <% if (bookings && bookings.length) { %>
      <div class="table-responsive">
        <table class="table table-striped">
          <thead class="table-dark">
            <tr>
              <th>Service</th>
              <th>Name</th>
              <th>Date</th>
              <th>Contact</th>
              <th>Time</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(b => { %>
              <tr>
                <td><%= b.service ? b.service.name : '—' %></td>
                <td><%= b.customerName %></td>
                <td><%= new Date(b.date).toLocaleDateString() %></td>
                <td><%= b.contactMethod === 'email' ? b.email : b.phone %></td>
                <td><%= b.timeSlot %></td>
                <td><span class="badge bg-<%= b.status === 'approved' ? 'success' : b.status === 'rejected' ? 'danger' : 'warning' %>"><%= b.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p>No bookings yet. <a href="/services">Book a service</a></p>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
