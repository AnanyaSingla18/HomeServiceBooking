<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Home Services</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <%- include('navbar') %>

  <main>
    <div class="container-fluid ps-0 pe-0">
      <!-- Hero Image Section - Larger -->
      <div class="hero-section">
        <img 
          src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?auto=format&fit=crop&w=2000&q=80"
          class="hero-image"
          alt="Professional home service"
        >
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <h1 class="hero-title">Welcome to Home Service Booking</h1>
          <p class="hero-subtitle">Trusted professionals at your doorstep — fast, reliable, and affordable.</p>
          <a href="/services" class="btn btn-light btn-lg hero-btn">
            🔧 View Services
          </a>
        </div>
      </div>
    </div>

    <div class="container py-5">
      <!-- Why Choose Us -->
      <section class="my-5">
        <div class="text-center mb-5">
          <h2 class="section-heading">Why Choose Us?</h2>
          <p class="section-subheading">We bring quality service to your home</p>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="feature-card">
              <div class="feature-icon">⭐</div>
              <h5 class="feature-title">Trusted Professionals</h5>
              <p class="feature-text">Vetted and rated experts for every job with years of experience.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-card">
              <div class="feature-icon">⚡</div>
              <h5 class="feature-title">Easy Booking</h5>
              <p class="feature-text">Book in just a few clicks with flexible time slots.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-card">
              <div class="feature-icon">💯</div>
              <h5 class="feature-title">Satisfaction Guaranteed</h5>
              <p class="feature-text">Reliable service backed by our support team.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Reviews Section -->
      <section class="my-5 py-5 border-top border-bottom">
        <div class="text-center mb-5">
          <h2 class="section-heading">Customer Reviews</h2>
          <p class="section-subheading">See what our customers say about our services</p>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="review-card">
              <div class="review-stars">⭐⭐⭐⭐⭐</div>
              <p class="review-text">"Amazing service! The plumber arrived on time and fixed everything perfectly. Highly recommend!"</p>
              <div class="review-author">- Rajesh Kumar</div>
              <div class="review-service">Plumbing Service</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="review-card">
              <div class="review-stars">⭐⭐⭐⭐⭐</div>
              <p class="review-text">"Quick, professional, and affordable. The electrician was very knowledgeable and courteous."</p>
              <div class="review-author">- Priya Sharma</div>
              <div class="review-service">Electrical Service</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="review-card">
              <div class="review-stars">⭐⭐⭐⭐⭐</div>
              <p class="review-text">"My home looks spotless! The cleaning team was thorough and respectful of my space."</p>
              <div class="review-author">- Anita Patel</div>
              <div class="review-service">Home Cleaning</div>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="bg-dark text-white text-center py-3 mt-5">
    <p class="m-0">&copy; Home Service Booking</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
