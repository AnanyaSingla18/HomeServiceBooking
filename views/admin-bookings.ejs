<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Admin - Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('navbar') %>
  <div class="container py-5">
    <h1 class="mb-4">📋 Bookings Management</h1>
    <% if (bookings && bookings.length) { %>
      <div class="table-responsive">
        <table class="table table-striped">
          <thead class="table-dark">
            <tr>
              <th>Service</th>
              <th>Name</th>
              <th>Date</th>
              <th>Contact</th>
              <th>Time</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(b => { %>
              <tr id="row-<%= b._id || b.id %>">
                <td><%= b.service ? b.service.name : '—' %></td>
                <td><%= b.customerName %></td>
                <td><%= new Date(b.date).toLocaleString() %></td>
                <td><%= b.contactMethod === 'email' ? b.email : b.phone %></td>
                <td><%= b.timeSlot %></td>
                <td id="status-<%= b._id || b.id %>"><span class="badge bg-<%= b.status === 'approved' ? 'success' : b.status === 'rejected' ? 'danger' : 'warning' %>"><%= b.status %></span></td>
                <td>
                  <% if (b.status === 'pending') { %>
                    <button class="btn btn-success btn-sm me-1" onclick="action('<%= b._id || b.id %>','approve')">✅ Approve</button>
                    <button class="btn btn-danger btn-sm" onclick="action('<%= b._id || b.id %>','reject')">❌ Reject</button>
                  <% } else { %>
                    <small><%= b.approvedBy ? b.approvedBy.email : '—' %></small>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p>No bookings.</p>
    <% } %>
  </div>

  <script>
    async function action(id, act) {
      const url = `/admin/bookings/${id}/${act}`;
      try {
        const res = await fetch(url, { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' } });
        const json = await res.json();
        if (res.ok) {
          document.getElementById('status-' + id).innerHTML = '<span class="badge bg-' + (json.booking.status === 'approved' ? 'success' : 'danger') + '">' + json.booking.status + '</span>';
        } else {
          alert(json.error || 'Failed');
        }
      } catch (err) {
        alert('Error');
      }
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>