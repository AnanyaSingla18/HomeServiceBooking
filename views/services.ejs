<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Services</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('navbar') %>
  <div class="container py-5">
    <div class="page-header mb-5">
      <h1 class="page-title">Available Services</h1>
      <p class="page-subtitle">Choose the service you need and proceed to a smooth booking experience.</p>
    </div>
    <% if (services && services.length) { %>
      <div class="services-grid">
        <% services.forEach(s => { %>
          <div class="service-card">
            <div class="service-header">
              <h4 class="service-title"><%= s.name %></h4>
            </div>
            <div class="service-body">
              <p class="service-description"><%= s.description %></p>
              <div class="service-price">₹<%= s.price %></div>
              
              <div class="service-providers mb-4">
                <h6 class="providers-title">Available Providers</h6>
                <% if (s.providers && s.providers.length) { %>
                  <% s.providers.forEach(provider => { %>
                    <div class="provider-item">
                      <strong><%= provider.name %></strong>
                      <div class="text-muted small"><%= provider.note %></div>
                      <a href="tel:<%= provider.phone %>" class="provider-phone">📞 <%= provider.phone %></a>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="provider-item text-muted">Our nearest expert will contact you after booking.</div>
                <% } %>
              </div>
              
              <a href="/booking?serviceId=<%= s._id || s.id %>" class="btn btn-primary w-100">Book Now</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">🔧</div>
        <h4>No services available</h4>
        <p>Check back soon for available services.</p>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
