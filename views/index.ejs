<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Home Services</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('navbar') %>

  <main>
    <div class="container py-5">

      <!-- Hero Image Section -->
      <div class="text-center my-4 w-100">
        <div class="position-relative">
          <img 
            src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?auto=format&fit=crop&w=1600&q=80"
            class="img-fluid w-100 rounded"
            style="max-height:350px; object-fit:cover;"
          >
          <div class="position-absolute top-50 start-50 translate-middle text-center text-white" 
               style="text-shadow:0 2px 6px rgba(0,0,0,0.6);">
            <h2 class="display-6">Welcome to Home Service Booking</h2>
            <p class="lead">Trusted professionals at your doorstep — fast, reliable, and affordable.</p>

            <a href="/services" class="btn btn-light btn-lg mt-3">
              🔧 View Services
            </a>
          </div>
        </div>
      </div>

      <!-- Why Choose Us -->
      <div class="mt-5">
        <h3 class="mb-4">Why choose us?</h3>
        <div class="row">
          <div class="col-md-4 mb-3">
            <div class="card h-100 p-3 text-center shadow-sm">
              <h5 class="mb-2">⭐ Trusted Professionals</h5>
              <p class="mb-0">Vetted and rated experts for every job.</p>
            </div>
          </div>
          <div class="col-md-4 mb-3">
            <div class="card h-100 p-3 text-center shadow-sm">
              <h5 class="mb-2">⚡ Easy Booking</h5>
              <p class="mb-0">Book in just a few clicks with flexible slots.</p>
            </div>
          </div>
          <div class="col-md-4 mb-3">
            <div class="card h-100 p-3 text-center shadow-sm">
              <h5 class="mb-2">💯 Satisfaction Guaranteed</h5>
              <p class="mb-0">Reliable service backed by our support team.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="bg-dark text-white text-center py-3 mt-5">
    <p class="m-0">&copy; Home Service Booking</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
