<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('navbar') %>
  <div class="container py-5">
    <div class="page-header mb-5">
      <h1 class="page-title">My Bookings</h1>
      <p class="page-subtitle">Track all your scheduled services and check booking status at a glance.</p>
    </div>
    <% if (bookings && bookings.length) { %>
      <div class="bookings-grid">
        <% bookings.forEach(b => { %>
          <div class="booking-card">
            <div class="booking-header">
              <h5 class="booking-service"><%= b.service ? b.service.name : 'Service' %></h5>
              <span class="badge bg-<%= b.status === 'approved' ? 'success' : b.status === 'rejected' ? 'danger' : 'warning' %>"><%= b.status || 'pending' %></span>
            </div>
            <div class="booking-details">
              <p class="booking-row">
                <strong>Name:</strong> <%= b.customerName %>
              </p>
              <p class="booking-row">
                <strong>Date:</strong> <%= new Date(b.date).toLocaleDateString('en-IN', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
              </p>
              <p class="booking-row">
                <strong>Time:</strong> <%= b.timeSlot %>
              </p>
              <p class="booking-row">
                <strong>Contact:</strong> <%= b.contactMethod === 'email' ? b.email : b.phone %>
              </p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">📅</div>
        <h4>No bookings yet</h4>
        <p>Start by booking a service from our available options.</p>
        <a href="/services" class="btn btn-primary mt-3">Browse Services</a>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
