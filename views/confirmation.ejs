<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Booking Confirmed</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('navbar') %>
  <div class="container py-5">
    <div class="confirmation-container">
      <div class="confirmation-header">
        <div class="confirmation-icon">✅</div>
        <h2>Booking Confirmed!</h2>
        <p class="mb-0">Your service booking has been successfully created</p>
      </div>
      <div class="confirmation-box">
        
        <!-- Booking Details Section -->
        <div class="confirmation-section">
          <h5 class="confirmation-section-title">📋 Booking Details</h5>
          <div class="confirmation-row">
            <span class="confirmation-label">Booking ID:</span>
            <span class="confirmation-value font-monospace" style="font-size: 0.9rem;"><%= booking._id || booking.id %></span>
          </div>
          <div class="confirmation-row">
            <span class="confirmation-label">Service:</span>
            <span class="confirmation-value"><%= booking.service ? booking.service.name : '—' %></span>
          </div>
          <div class="confirmation-row">
            <span class="confirmation-label">Customer Name:</span>
            <span class="confirmation-value"><%= booking.customerName %></span>
          </div>
          <div class="confirmation-row">
            <span class="confirmation-label">Date:</span>
            <span class="confirmation-value"><%= new Date(booking.date).toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          </div>
          <div class="confirmation-row">
            <span class="confirmation-label">Time:</span>
            <span class="confirmation-value"><%= booking.timeSlot %></span>
          </div>
          <div class="confirmation-row">
            <span class="confirmation-label">Contact Method:</span>
            <span class="confirmation-value"><%= booking.contactMethod === 'email' ? '📧 Email' : '📱 Phone' %></span>
          </div>
          <div class="confirmation-row">
            <span class="confirmation-label">Contact Info:</span>
            <span class="confirmation-value"><%= booking.contactMethod === 'email' ? booking.email : booking.phone %></span>
          </div>
        </div>

        <!-- Provider Section -->
        <% if (booking.service && booking.service.providers && booking.service.providers.length) { %>
          <div class="confirmation-section">
            <h5 class="confirmation-section-title">👨‍🔧 Your Service Provider</h5>
            <div class="confirmation-row">
              <span class="confirmation-label">Provider Name:</span>
              <span class="confirmation-value"><%= booking.service.providers[0].name %></span>
            </div>
            <div class="confirmation-row">
              <span class="confirmation-label">Specialization:</span>
              <span class="confirmation-value"><%= booking.service.providers[0].note %></span>
            </div>
            <div class="confirmation-row">
              <span class="confirmation-label">Contact:</span>
              <span class="confirmation-value">
                <a href="tel:<%= booking.service.providers[0].phone %>" class="btn btn-sm btn-outline-primary">
                  📞 <%= booking.service.providers[0].phone %>
                </a>
              </span>
            </div>
          </div>
        <% } %>

        <!-- Status Section -->
        <div class="confirmation-section">
          <h5 class="confirmation-section-title">📊 Status</h5>
          <div class="confirmation-row">
            <span class="confirmation-label">Booking Status:</span>
            <span>
              <span class="badge bg-<%= booking.status === 'approved' ? 'success' : booking.status === 'rejected' ? 'danger' : 'warning' %> px-3 py-2" style="font-size: 0.9rem;">
                <%= booking.status ? booking.status.charAt(0).toUpperCase() + booking.status.slice(1) : 'Pending' %>
              </span>
            </span>
          </div>
          <% if (booking.approvedBy) { %>
            <div class="confirmation-row">
              <span class="confirmation-label">Approved by:</span>
              <span class="confirmation-value"><%= booking.approvedBy.email || 'Admin' %></span>
            </div>
            <div class="confirmation-row">
              <span class="confirmation-label">Approved at:</span>
              <span class="confirmation-value"><%= booking.approvedAt ? new Date(booking.approvedAt).toLocaleString('en-IN') : '—' %></span>
            </div>
          <% } %>
        </div>

        <!-- Actions -->
        <div class="confirmation-actions">
          <a href="/" class="btn btn-primary btn-lg">
            🏠 Back to Home
          </a>
          <a href="/services" class="btn btn-outline-primary btn-lg">
            🔧 Book Another Service
          </a>
          <a href="/bookings" class="btn btn-outline-secondary btn-lg">
            📋 View All Bookings
          </a>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>